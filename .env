# Environment — DO NOT commit this file
# Copy from .env.example and fill in your values

# MongoDB connection string
# Local:   mongodb://127.0.0.1:27017/portfolio_anand
# Atlas:   mongodb+srv://<user>:<password>@cluster.mongodb.net/portfolio_anand
MONGO_URI=mongodb://127.0.0.1:27017/portfolio_anand

# Port the Express server listens on
PORT=3001

# Secret key to access the admin messages endpoint
# Change this to a long random string before deploying!
ADMIN_KEY=changeme_super_secret_key_2024

# Node environment
NODE_ENV=development
